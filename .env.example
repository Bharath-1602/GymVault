# GymVault - Local Development Environment Configuration
# Copy this to .env for local development

# Flask Config
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True

# MongoDB Config (Local fallback)
MONGODB_URI=mongodb://localhost:27017/gymvault
MONGODB_DB_NAME=gymvault

# AWS Configuration (Leave blank to use local fallback simulation)
AWS_REGION=us-east-1
S3_BUCKET_NAME=
KMS_KEY_ARN=
SNS_TOPIC_ARN=

# Gym Configuration
GYM_NAME=GymVault Fitness Center
GYM_EMAIL=admin@gymvault.com
ALERT_DAYS_BEFORE=7
